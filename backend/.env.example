# Port the API listens on
PORT=8080

# Frontend origin — used for the post-login redirect and CORS.
FRONTEND_URL=http://localhost:3000

# GitHub OAuth App credentials (github.com/settings/developers).
# Callback URL registered on the app must be <backend>/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# What the user grants. "repo" is needed to read PRIVATE vaults;
# use "read:user" alone for public-only.
OAUTH_SCOPE=read:user repo

# GitHub API base (override only for GitHub Enterprise)
GITHUB_API=https://api.github.com
